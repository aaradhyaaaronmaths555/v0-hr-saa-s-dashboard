generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organisation {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  employees  Employee[]
  policies   Policy[]
  certificates Certificate[]
  incidents  WHSIncident[]
  policyReminderSchedules PolicyReminderSchedule[]
  policyReminderEvents PolicyReminderEvent[]
}

model User {
  id             String   @id
  email          String   @unique
  fullName       String?  @map("full_name")
  organisationId String   @map("organisation_id")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
}

model Employee {
  id             String   @id @default(cuid())
  organisationId String   @map("organisation_id")
  name           String
  email          String?
  onboardingStatus String @default("Not Started") @map("onboarding_status")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  certificates Certificate[]
  acknowledgements PolicyAcknowledgement[]
  rightToWork RightToWork?
  fairWorkChecklist FairWorkChecklist?
  policyReminderEvents PolicyReminderEvent[]
}

model Certificate {
  id           String   @id @default(cuid())
  employeeId  String   @map("employee_id")
  type        String
  expiryDate  DateTime? @map("expiry_date")
  status      String   @default("Valid")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Policy {
  id             String   @id @default(cuid())
  organisationId String   @map("organisation_id")
  title          String
  description   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organisation    Organisation          @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  acknowledgements PolicyAcknowledgement[]
  reminderSchedule PolicyReminderSchedule?
  reminderEvents PolicyReminderEvent[]
}

model PolicyAcknowledgement {
  id        String   @id @default(cuid())
  policyId  String   @map("policy_id")
  employeeId String  @map("employee_id")
  acknowledgedAt DateTime? @map("acknowledged_at")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  policy   Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model WHSIncident {
  id               String   @id @default(cuid())
  organisationId   String   @map("organisationId")
  incidentType     String   @map("incidentType")
  incidentDate     DateTime @map("incidentDate")
  employeesInvolved String  @map("employeesInvolved")
  correctiveAction String   @map("correctiveAction")
  preventionSteps  String?  @map("preventionSteps")
  assignedTo       String?  @map("assignedTo")
  dateClosed       DateTime? @map("dateClosed")
  status           String   @default("New")
  createdAt        DateTime @default(now()) @map("createdAt")
  updatedAt        DateTime @updatedAt @map("updatedAt")

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  timeline     WHSIncidentTimeline[]
}

model RightToWork {
  id             String   @id @default(cuid())
  employeeId     String   @unique @map("employeeId")
  visaType       String   @map("visaType")
  visaExpiryDate DateTime @map("visaExpiryDate")
  createdAt      DateTime @default(now()) @map("createdAt")
  updatedAt      DateTime @updatedAt @map("updatedAt")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model FairWorkChecklist {
  id                    String   @id @default(cuid())
  employeeId            String   @unique @map("employeeId")
  taxFileDeclaration    Boolean  @default(false) @map("taxFileDeclaration")
  superChoiceForm       Boolean  @default(false) @map("superChoiceForm")
  fairWorkInfoStatement Boolean  @default(false) @map("fairWorkInfoStatement")
  createdAt             DateTime @default(now()) @map("createdAt")
  updatedAt             DateTime @updatedAt @map("updatedAt")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model WHSIncidentTimeline {
  id             String   @id @default(cuid())
  organisationId String   @map("organisationId")
  incidentId     String   @map("incidentId")
  eventType      String   @map("eventType")
  statusFrom     String?  @map("statusFrom")
  statusTo       String?  @map("statusTo")
  comment        String? 
  assignedTo     String?  @map("assignedTo")
  createdAt      DateTime @default(now()) @map("createdAt")

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  incident     WHSIncident  @relation(fields: [incidentId], references: [id], onDelete: Cascade)
}

model PolicyReminderSchedule {
  id                String   @id @default(cuid())
  organisationId    String   @map("organisationId")
  policyId          String   @unique @map("policyId")
  autoRemindEnabled Boolean  @default(false) @map("autoRemindEnabled")
  cadenceDays       Int      @default(3) @map("cadenceDays")
  deadlineAt        DateTime? @map("deadlineAt")
  nextRunAt         DateTime? @map("nextRunAt")
  lastRunAt         DateTime? @map("lastRunAt")
  createdAt         DateTime @default(now()) @map("createdAt")
  updatedAt         DateTime @updatedAt @map("updatedAt")

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  policy       Policy       @relation(fields: [policyId], references: [id], onDelete: Cascade)
}

model PolicyReminderEvent {
  id             String   @id @default(cuid())
  organisationId String   @map("organisationId")
  policyId       String   @map("policyId")
  employeeId     String   @map("employeeId")
  sentAt         DateTime @default(now()) @map("sentAt")
  triggerType    String   @default("manual") @map("triggerType")
  status         String   @default("sent")
  errorMessage   String?  @map("errorMessage")
  createdAt      DateTime @default(now()) @map("createdAt")

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  policy       Policy       @relation(fields: [policyId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}
